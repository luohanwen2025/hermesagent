---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'zh';
const t = useTranslations(lang);
---

<BaseLayout title={t('hero.title')} lang={lang}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-500/5 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-500/10 rounded-full blur-[120px] -z-10"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 relative">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium px-4 py-1.5 rounded-full mb-8">
          <span class="w-2 h-2 bg-brand-400 rounded-full animate-pulse"></span>
          {t('hero.tag')}
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6">
          <span class="gradient-text">{t('hero.title')}</span>
        </h1>

        <p class="text-lg md:text-xl text-gray-400 leading-relaxed max-w-3xl mx-auto mb-10">
          {t('hero.subtitle')}
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/zh/docs/install" class="btn-primary text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            {t('hero.cta.install')}
          </a>
          <a href="/zh/docs/features" class="btn-secondary text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            {t('hero.cta.docs')}
          </a>
          <a href="https://github.com/nousresearch/hermes-agent" target="_blank" rel="noopener" class="btn-secondary text-lg">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            {t('hero.cta.github')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title">{t('features.title')}</h2>
        <p class="section-subtitle mx-auto">{t('features.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card group">
          <div class="w-12 h-12 bg-brand-500/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('features.memory.title')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('features.memory.desc')}</p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 bg-brand-500/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('features.platforms.title')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('features.platforms.desc')}</p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 bg-brand-500/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('features.subagents.title')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('features.subagents.desc')}</p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 bg-brand-500/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('features.scheduling.title')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('features.scheduling.desc')}</p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 bg-brand-500/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('features.skills.title')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('features.skills.desc')}</p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 bg-brand-500/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('features.sandbox.title')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('features.sandbox.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Install Section -->
  <section class="py-20 bg-gray-900/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title">{t('install.title')}</h2>
        <p class="section-subtitle mx-auto">{t('install.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-10 h-10 bg-brand-500 text-gray-900 rounded-full flex items-center justify-center font-bold text-lg mx-auto mb-4">1</div>
          <h3 class="text-white font-semibold mb-2">{t('install.step1')}</h3>
          <div class="code-block text-left mt-3">
            <code class="text-brand-300">curl -fsSL https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh | bash</code>
          </div>
          <p class="text-gray-500 text-xs mt-2">{t('install.step1.desc')}</p>
        </div>

        <div class="text-center">
          <div class="w-10 h-10 bg-brand-500 text-gray-900 rounded-full flex items-center justify-center font-bold text-lg mx-auto mb-4">2</div>
          <h3 class="text-white font-semibold mb-2">{t('install.step2')}</h3>
          <div class="code-block text-left mt-3">
            <code class="text-brand-300">hermes setup</code>
          </div>
          <p class="text-gray-500 text-xs mt-2">{t('install.step2.desc')}</p>
        </div>

        <div class="text-center">
          <div class="w-10 h-10 bg-brand-500 text-gray-900 rounded-full flex items-center justify-center font-bold text-lg mx-auto mb-4">3</div>
          <h3 class="text-white font-semibold mb-2">{t('install.step3')}</h3>
          <div class="code-block text-left mt-3">
            <code class="text-brand-300">hermes</code>
          </div>
          <p class="text-gray-500 text-xs mt-2">{t('install.step3.desc')}</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/zh/docs/install" class="btn-primary">
          {t('install.go')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Requirements -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card">
        <h3 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          {t('install.requirements')}
        </h3>
        <ul class="space-y-2">
          <li class="flex items-start gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-brand-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            {t('install.req1')}
          </li>
          <li class="flex items-start gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-brand-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            {t('install.req2')}
          </li>
          <li class="flex items-start gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-brand-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            {t('install.req3')}
          </li>
          <li class="flex items-start gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 text-gray-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01"/></svg>
            {t('install.req4')}
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
